<%@ page contentType="text/html; charset=UTF-8" %>
<%@ page import="logica.GestorTickets" %>
<%@ page import="modelo.Ticket" %>

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <title>Editar Ticket | SkyManager</title>

    <!-- ========================================= -->
    <!-- GOOGLE FONTS -->
    <!-- ========================================= -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <!-- ========================================= -->
    <!-- BOOTSTRAP -->
    <!-- ========================================= -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- ========================================= -->
    <!-- ICONOS -->
    <!-- ========================================= -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- ========================================= -->
    <!-- ESTILOS -->
    <!-- ========================================= -->

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        body{

            background:
                radial-gradient(circle at top left,
                rgba(212,175,55,0.10),
                transparent 25%),

                radial-gradient(circle at bottom right,
                rgba(212,175,55,0.08),
                transparent 25%),

                #050505;

            min-height:100vh;

            font-family:'Poppins',sans-serif;

            color:white;

            display:flex;

            justify-content:center;

            align-items:center;

            padding:40px;
        }

        /* =========================================
           CARD
        ========================================= */

        .edit-card{

            width:100%;
            max-width:700px;

            background:rgba(255,255,255,0.04);

            backdrop-filter:blur(18px);

            border-radius:28px;

            border:1px solid rgba(255,255,255,0.08);

            box-shadow:
                0 15px 40px rgba(0,0,0,0.45);

            padding:45px;

            animation:fadeIn 0.8s ease;
        }

        @keyframes fadeIn{

            from{
                opacity:0;
                transform:translateY(20px);
            }

            to{
                opacity:1;
                transform:translateY(0);
            }
        }

        /* =========================================
           HEADER
        ========================================= */

        .header{

            text-align:center;

            margin-bottom:35px;
        }

        .logo-circle{

            width:90px;
            height:90px;

            margin:auto;

            border-radius:50%;

            background:linear-gradient(
                    135deg,
                    #d4af37,
                    #f5d76e
            );

            display:flex;

            align-items:center;

            justify-content:center;

            margin-bottom:20px;

            box-shadow:
                0 10px 30px rgba(212,175,55,0.35);
        }

        .logo-circle i{

            font-size:40px;

            color:#111111;
        }

        .titulo{

            font-size:32px;

            font-weight:700;

            margin-bottom:8px;
        }

        .subtitulo{

            color:#9ca3af;

            font-size:14px;

            letter-spacing:1px;
        }

        /* =========================================
           LABELS
        ========================================= */

        .form-label{

            color:#e5e7eb;

            margin-bottom:10px;

            font-weight:500;
        }

        /* =========================================
           INPUTS
        ========================================= */

        .form-control{

            height:55px;

            border-radius:16px;

            background:#0f0f0f;

            border:1px solid #2a2a2a;

            color:white;

            padding-left:18px;
        }

        .form-control:focus{

            background:#111111;

            color:white;

            border-color:#d4af37;

            box-shadow:
                0 0 0 0.2rem rgba(212,175,55,0.15);
        }

        .form-control:disabled{

            background:#1a1a1a;

            color:#9ca3af;
        }

        /* =========================================
           BOTONES
        ========================================= */

        .btn{

            height:55px;

            border:none;

            border-radius:16px;

            font-weight:600;

            transition:0.3s;
        }

        .btn-update{

            background:linear-gradient(
                    135deg,
                    #d4af37,
                    #f5d76e
            );

            color:#111111;
        }

        .btn-update:hover{

            transform:translateY(-3px);

            box-shadow:
                0 10px 25px rgba(212,175,55,0.35);
        }

        .btn-back{

            background:#1f2937;

            color:white;
        }

        .btn-back:hover{

            background:#374151;

            color:white;
        }

        /* =========================================
           FOOTER
        ========================================= */

        .footer{

            text-align:center;

            margin-top:25px;

            color:#777777;

            font-size:13px;
        }

        /* =========================================
           RESPONSIVE
        ========================================= */

        @media(max-width:768px){

            .edit-card{

                padding:30px;
            }

            .titulo{

                font-size:26px;
            }
        }

    </style>

</head>

<body>

<%

    // =========================================
    // OBTENER GESTOR
    // =========================================

    GestorTickets gestor =
            (GestorTickets) application.getAttribute("gestor");

    // =========================================
    // OBTENER ID
    // =========================================

    String id =
            request.getParameter("id");

    // =========================================
    // BUSCAR TICKET
    // =========================================

    Ticket ticket =
            gestor.buscarPorId(id);

%>

<!-- ========================================= -->
<!-- CARD -->
<!-- ========================================= -->

<div class="edit-card">

    <!-- HEADER -->

    <div class="header">

        <div class="logo-circle">

            <i class="bi bi-pencil-square"></i>

        </div>

        <div class="titulo">

            Editar Ticket

        </div>

        <div class="subtitulo">

            SKYMANAGER PREMIUM FLIGHT SYSTEM

        </div>

    </div>

    <!-- FORMULARIO -->

    <form action="${pageContext.request.contextPath}/tickets"
          method="post">

        <!-- ACCION -->

        <input type="hidden"
               name="accion"
               value="editar">

        <!-- ID -->

        <input type="hidden"
               name="id"
               value="<%= ticket.getId() %>">

        <!-- ID VISUAL -->

        <div class="mb-4">

            <label class="form-label">

                ID DEL TICKET

            </label>

            <input type="text"
                   class="form-control"
                   value="<%= ticket.getId() %>"
                   disabled>

        </div>

        <!-- PASAJERO -->

        <div class="mb-4">

            <label class="form-label">

                PASAJERO

            </label>

            <input type="text"
                   class="form-control"
                   name="pasajero"
                   value="<%= ticket.getPasajero() %>"
                   required>

        </div>

        <!-- ORIGEN -->

        <div class="mb-4">

            <label class="form-label">

                ORIGEN

            </label>

            <input type="text"
                   class="form-control"
                   name="origen"
                   value="<%= ticket.getOrigen() %>"
                   required>

        </div>

        <!-- DESTINO -->

        <div class="mb-5">

            <label class="form-label">

                DESTINO

            </label>

            <input type="text"
                   class="form-control"
                   name="destino"
                   value="<%= ticket.getDestino() %>"
                   required>

        </div>

        <!-- BOTONES -->

        <div class="d-flex gap-3">

            <!-- ACTUALIZAR -->

            <button type="submit"
                    class="btn btn-update w-100">

                <i class="bi bi-check-circle-fill"></i>

                Actualizar Ticket

            </button>

            <!-- VOLVER -->

            <a href="${pageContext.request.contextPath}/tickets"
               class="btn btn-back w-100 d-flex align-items-center justify-content-center">

                <i class="bi bi-arrow-left-circle-fill me-2"></i>

                Volver

            </a>

        </div>

    </form>

    <!-- FOOTER -->

    <div class="footer">

        © 2026 SkyManager · Sistema Premium

    </div>

</div>

</body>
</html>