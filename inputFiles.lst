<%@ page contentType="text/html; charset=UTF-8" %>
<%@ page import="logica.GestorTickets" %>
<%@ page import="estructura.NodoDoble" %>

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Recorrido Inverso</title>

    <!-- GOOGLE FONTS -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <!-- BOOTSTRAP -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- ICONOS -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{

    background:#0a0a0a;

    font-family:'Poppins',sans-serif;

    color:#f5f5f5;

    overflow-x:hidden;
}

/* ====================================
   SCROLLBAR
==================================== */

::-webkit-scrollbar{
    width:10px;
}

::-webkit-scrollbar-track{
    background:#111111;
}

::-webkit-scrollbar-thumb{
    background:#2a2a2a;
    border-radius:10px;
}

/* ====================================
   SIDEBAR
==================================== */

.sidebar{

    position:fixed;

    top:0;
    left:0;

    width:270px;

    height:100vh;

    background:linear-gradient(
            180deg,
            #111111,
            #181818
    );

    padding-top:30px;

    border-right:1px solid #2a2a2a;

    box-shadow:4px 0 30px rgba(0,0,0,0.45);

    z-index:1000;
}

.logo-area{

    text-align:center;

    margin-bottom:45px;
}

.logo-circle{

    width:90px;
    height:90px;

    margin:auto;

    border-radius:50%;

    background:linear-gradient(
            135deg,
            #d4af37,
            #f5d76e
    );

    display:flex;

    align-items:center;

    justify-content:center;

    margin-bottom:18px;

    box-shadow:0 10px 30px rgba(212,175,55,0.35);
}

.logo-circle i{

    font-size:40px;

    color:#111111;
}

.logo-area h3{

    color:#f5f5f5;

    font-weight:600;

    margin-bottom:5px;
}

.logo-area small{

    color:#9ca3af;

    letter-spacing:1px;

    font-size:12px;
}

/* ====================================
   MENU
==================================== */

.sidebar a{

    display:flex;

    align-items:center;

    gap:14px;

    color:#b0b0b0;

    padding:16px 28px;

    text-decoration:none;

    transition:0.3s;

    font-weight:500;

    border-left:3px solid transparent;
}

.sidebar a:hover{

    background:#1f1f1f;

    color:#d4af37;

    border-left:3px solid #d4af37;

    padding-left:35px;
}

.sidebar .active{

    background:#1f1f1f;

    color:#d4af37;

    border-left:3px solid #d4af37;
}

/* ====================================
   MAIN
==================================== */

.main-content{

    margin-left:290px;

    padding:35px;
}

/* ====================================
   TOPBAR
==================================== */

.topbar{

    background:rgba(255,255,255,0.04);

    backdrop-filter:blur(14px);

    padding:28px;

    border-radius:24px;

    border:1px solid rgba(255,255,255,0.06);

    box-shadow:0 10px 35px rgba(0,0,0,0.35);

    margin-bottom:35px;
}

.titulo{

    font-weight:700;

    color:#f5f5f5;
}

.subtitulo{

    color:#9ca3af;
}

/* ====================================
   INFO PANEL
==================================== */

.info-panel{

    background:rgba(255,255,255,0.04);

    backdrop-filter:blur(12px);

    border-radius:24px;

    padding:30px;

    border:1px solid rgba(255,255,255,0.05);

    box-shadow:0 10px 35px rgba(0,0,0,0.35);

    margin-bottom:35px;
}

.info-box{

    text-align:center;
}

.info-box i{

    font-size:35px;

    color:#d4af37;

    margin-bottom:15px;
}

.info-box h5{

    font-weight:600;

    margin-bottom:10px;
}

.info-box p{

    color:#9ca3af;

    font-size:14px;
}

/* ====================================
   TIMELINE
==================================== */

.timeline{

    position:relative;

    margin-top:50px;
}

.timeline::before{

    content:"";

    position:absolute;

    left:35px;

    top:0;

    width:4px;

    height:100%;

    background:linear-gradient(
            180deg,
            #d4af37,
            #f5d76e
    );

    border-radius:10px;
}

.timeline-item{

    position:relative;

    margin-bottom:40px;

    padding-left:100px;
}

.timeline-icon{

    position:absolute;

    left:12px;

    top:5px;

    width:50px;

    height:50px;

    border-radius:50%;

    background:linear-gradient(
            135deg,
            #d4af37,
            #f5d76e
    );

    color:#111111;

    display:flex;

    align-items:center;

    justify-content:center;

    font-weight:bold;

    font-size:18px;

    z-index:10;

    box-shadow:0 8px 20px rgba(212,175,55,0.3);
}

/* ====================================
   CARDS
==================================== */

.timeline-card{

    background:rgba(255,255,255,0.04);

    backdrop-filter:blur(12px);

    border-radius:24px;

    padding:28px;

    border:1px solid rgba(255,255,255,0.05);

    box-shadow:0 10px 35px rgba(0,0,0,0.35);

    transition:0.35s;
}

.timeline-card:hover{

    transform:translateY(-5px);

    border:1px solid rgba(212,175,55,0.18);
}

.ticket-title{

    color:#d4af37;

    font-weight:700;
}

.label{

    color:#9ca3af;

    font-size:14px;
}

.value{

    font-weight:600;

    font-size:17px;
}

/* ====================================
   BADGE
==================================== */

.badge-custom{

    background:#111111;

    color:#d4af37;

    padding:10px 15px;

    border-radius:12px;

    border:1px solid rgba(212,175,55,0.2);
}

/* ====================================
   EMPTY
==================================== */

.empty-card{

    background:rgba(255,255,255,0.04);

    border-radius:24px;

    padding:40px;

    text-align:center;

    border:1px solid rgba(255,255,255,0.05);
}

.empty-card i{

    font-size:60px;

    color:#d4af37;

    margin-bottom:20px;
}

/* ====================================
   RESPONSIVE
==================================== */

@media(max-width:991px){

    .sidebar{

        position:relative;

        width:100%;

        height:auto;
    }

    .main-content{

        margin-left:0;
    }

    .timeline::before{

        left:20px;
    }

    .timeline-item{

        padding-left:70px;
    }

    .timeline-icon{

        left:0;
    }
}

</style>

</head>

<body>

<%

    GestorTickets gestor =
            (GestorTickets) application.getAttribute("gestor");

%>

<!-- ====================================
     SIDEBAR
==================================== -->

<div class="sidebar">

    <div class="logo-area">

        <div class="logo-circle">

            <i class="bi bi-airplane-fill"></i>

        </div>

        <h3>
            SkyManager
        </h3>

        <small>
            PREMIUM FLIGHT SYSTEM
        </small>

    </div>

    <a href="${pageContext.request.contextPath}/views/dashboard.jsp">

        <i class="bi bi-speedometer2"></i>

        Dashboard

    </a>

    <a href="${pageContext.request.contextPath}/tickets">

        <i class="bi bi-ticket-detailed-fill"></i>

        Gestión Tickets

    </a>

    <a href="${pageContext.request.contextPath}/views/recorridoInverso.jsp"
       class="active">

        <i class="bi bi-arrow-left-right"></i>

        Recorrido Inverso

    </a>

    <a href="${pageContext.request.contextPath}/descargar">

        <i class="bi bi-download"></i>

        Descargar TXT

    </a>

</div>

<!-- ====================================
     MAIN
==================================== -->

<div class="main-content">

    <!-- TOPBAR -->

    <div class="topbar d-flex justify-content-between align-items-center">

        <div>

            <h3 class="titulo mb-1">

                Recorrido Inverso

            </h3>

            <small class="subtitulo">

                Visualización desde cola hasta cabeza

            </small>

        </div>

        <div>

            <span class="badge bg-primary p-3">

                <i class="bi bi-diagram-3-fill"></i>

                Lista Doble

            </span>

        </div>

    </div>

    <!-- TITULO -->

    <div class="mb-5">

        <h1 class="titulo display-5 mb-3">

            Línea Temporal Inversa

        </h1>

        <p class="subtitulo">

            Recorrido de nodos utilizando el puntero
            <strong>anterior</strong>
            desde la cola hasta la cabeza
            de la lista doblemente enlazada.

        </p>

    </div>

    <!-- INFO PANEL -->

    <div class="info-panel">

        <div class="row">

            <div class="col-md-4 mb-4">

                <div class="info-box">

                    <i class="bi bi-diagram-3-fill"></i>

                    <h5>
                        Estructura
                    </h5>

                    <p>
                        Lista doblemente enlazada
                    </p>

                </div>

            </div>

            <div class="col-md-4 mb-4">

                <div class="info-box">

                    <i class="bi bi-arrow-counterclockwise"></i>

                    <h5>
                        Recorrido
                    </h5>

                    <p>
                        Desde cola hacia cabeza
                    </p>

                </div>

            </div>

            <div class="col-md-4 mb-4">

                <div class="info-box">

                    <i class="bi bi-code-slash"></i>

                    <h5>
                        Implementación
                    </h5>

                    <p>
                        Uso del puntero anterior
                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- TIMELINE -->

    <div class="timeline">

    <%

        if (gestor != null &&
            gestor.getLista() != null &&
            gestor.getLista().getCola() != null) {

            NodoDoble actual =
                    gestor.getLista().getCola();

            int contador = 1;

            while(actual != null){

    %>

        <!-- ITEM -->

        <div class="timeline-item">

            <!-- ICONO -->

            <div class="timeline-icon">

                <%= contador %>

            </div>

            <!-- CARD -->

            <div class="timeline-card">

                <div class="d-flex justify-content-between align-items-center mb-4">

                    <h4 class="ticket-title mb-0">

                        Ticket:
                        <%= actual.dato.getId() %>

                    </h4>

                    <span class="badge-custom">

                        Nodo Inverso

                    </span>

                </div>

                <div class="row">

                    <div class="col-md-4 mb-3">

                        <div class="label">

                            Pasajero

                        </div>

                        <div class="value">

                            <%= actual.dato.getPasajero() %>

                        </div>

                    </div>

                    <div class="col-md-4 mb-3">

                        <div class="label">

                            Origen

                        </div>

                        <div class="value">

                            <%= actual.dato.getOrigen() %>

                        </div>

                    </div>

                    <div class="col-md-4 mb-3">

                        <div class="label">

                            Destino

                        </div>

                        <div class="value">

                            <%= actual.dato.getDestino() %>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    <%

                actual = actual.anterior;

                contador++;
            }

        } else {

    %>

        <!-- EMPTY -->

        <div class="empty-card">

            <i class="bi bi-exclamation-circle-fill"></i>

            <h3 class="mb-3">

                No existen tickets registrados

            </h3>

            <p class="text-muted">

                Actualmente no hay información
                disponible para realizar
                el recorrido inverso.

            </p>

        </div>

    <%

        }

    %>

    </div>

</div>

</body>
</html>