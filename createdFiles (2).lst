<%@ page contentType="text/html; charset=UTF-8" %>
<%@ page import="logica.GestorTickets" %>
<%@ page import="estructura.NodoDoble" %>

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>SkyManager | Gestión de Tickets</title>

    <!-- ===================================================== -->
    <!-- GOOGLE FONTS -->
    <!-- ===================================================== -->

    <link rel="preconnect"
          href="https://fonts.googleapis.com">

    <link rel="preconnect"
          href="https://fonts.gstatic.com"
          crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <!-- ===================================================== -->
    <!-- BOOTSTRAP -->
    <!-- ===================================================== -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- ===================================================== -->
    <!-- BOOTSTRAP ICONS -->
    <!-- ===================================================== -->

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- ===================================================== -->
    <!-- ESTILOS PREMIUM -->
    <!-- ===================================================== -->

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
        }

        html{
            scroll-behavior:smooth;
        }

        body{

            background:
                    radial-gradient(circle at top,
                    #1a1a1a,
                    #0a0a0a 60%);

            font-family:'Poppins',sans-serif;

            color:#f5f5f5;

            overflow-x:hidden;
        }

        /* =====================================================
           SCROLLBAR
        ===================================================== */

        ::-webkit-scrollbar{
            width:10px;
        }

        ::-webkit-scrollbar-track{
            background:#111111;
        }

        ::-webkit-scrollbar-thumb{
            background:#d4af37;
            border-radius:20px;
        }

        /* =====================================================
           SIDEBAR
        ===================================================== */

        .sidebar{

            position:fixed;

            top:0;
            left:0;

            width:280px;

            height:100vh;

            background:
                    linear-gradient(
                            180deg,
                            #111111,
                            #181818
                    );

            border-right:1px solid rgba(255,255,255,0.06);

            padding-top:30px;

            z-index:1000;

            box-shadow:
                    5px 0 30px rgba(0,0,0,0.45);
        }

        /* =====================================================
           LOGO
        ===================================================== */

        .logo-area{

            text-align:center;

            margin-bottom:50px;
        }

        .logo-circle{

            width:95px;
            height:95px;

            margin:auto;

            border-radius:50%;

            background:
                    linear-gradient(
                            135deg,
                            #d4af37,
                            #f5d76e
                    );

            display:flex;

            align-items:center;
            justify-content:center;

            margin-bottom:18px;

            box-shadow:
                    0 15px 35px rgba(212,175,55,0.35);
        }

        .logo-circle i{

            font-size:42px;

            color:#111111;
        }

        .logo-area h3{

            font-weight:700;

            color:#f5f5f5;
        }

        .logo-area small{

            color:#9ca3af;

            letter-spacing:2px;

            font-size:11px;
        }

        /* =====================================================
           SIDEBAR LINKS
        ===================================================== */

        .sidebar a{

            display:flex;

            align-items:center;

            gap:15px;

            padding:17px 30px;

            color:#b0b0b0;

            text-decoration:none;

            transition:0.3s ease;

            border-left:3px solid transparent;

            font-weight:500;
        }

        .sidebar a:hover{

            background:#1d1d1d;

            color:#d4af37;

            padding-left:38px;

            border-left:3px solid #d4af37;
        }

        .sidebar .active{

            background:#1d1d1d;

            color:#d4af37;

            border-left:3px solid #d4af37;
        }

        /* =====================================================
           MAIN CONTENT
        ===================================================== */

        .main-content{

            margin-left:300px;

            padding:35px;
        }

        /* =====================================================
           TOPBAR
        ===================================================== */

        .topbar{

            background:
                    rgba(255,255,255,0.04);

            backdrop-filter:blur(16px);

            -webkit-backdrop-filter:blur(16px);

            border-radius:24px;

            border:1px solid rgba(255,255,255,0.05);

            padding:28px;

            margin-bottom:35px;

            box-shadow:
                    0 10px 35px rgba(0,0,0,0.35);
        }

        .titulo{

            font-weight:700;
        }

        .subtitulo{

            color:#9ca3af;
        }

        /* =====================================================
           PANEL CARD
        ===================================================== */

        .panel-card{

            background:
                    rgba(255,255,255,0.04);

            backdrop-filter:blur(18px);

            -webkit-backdrop-filter:blur(18px);

            border-radius:24px;

            padding:30px;

            border:1px solid rgba(255,255,255,0.06);

            box-shadow:
                    0 10px 35px rgba(0,0,0,0.35);

            margin-bottom:25px;

            transition:0.35s ease;
        }

        .panel-card:hover{

            transform:translateY(-5px);

            border-color:
                    rgba(212,175,55,0.18);
        }

        /* =====================================================
           STATS
        ===================================================== */

        .stats-number{

            font-size:42px;

            font-weight:700;

            margin-top:12px;
        }

        /* =====================================================
           TABLE
        ===================================================== */

        .table{

            color:#f5f5f5;
        }

        .table thead{

            background:#111111;
        }

        .table th{

            border:none;

            color:#d4af37;

            text-align:center;
        }

        .table td{

            border-color:#2a2a2a;

            vertical-align:middle;
        }

        .table-hover tbody tr:hover{

            background:#1a1a1a;
        }

        /* =====================================================
           INPUTS
        ===================================================== */

        .form-control{

            background:
                    rgba(255,255,255,0.03);

            border:
                    1px solid rgba(255,255,255,0.06);

            color:#f5f5f5;

            border-radius:16px;

            padding:14px;

            transition:0.3s;
        }

        .form-control:focus{

            background:#151515;

            border-color:#d4af37;

            color:white;

            box-shadow:none;
        }

        .form-label{

            margin-bottom:10px;

            color:#f5f5f5;

            font-weight:500;
        }

        /* =====================================================
           BUTTONS
        ===================================================== */

        .btn{

            border-radius:14px;

            font-weight:500;

            transition:0.3s ease;

            letter-spacing:0.5px;
        }

        .btn:hover{

            transform:translateY(-2px);

            box-shadow:
                    0 8px 20px rgba(0,0,0,0.35);
        }

        .btn-primary{

            background:#d4af37;

            border:none;

            color:#111111;
        }

        .btn-primary:hover{

            background:#f5d76e;

            color:#111111;
        }

        .btn-success{

            background:#16a34a;

            border:none;
        }

        .btn-warning{

            color:#111111;
        }

        /* =====================================================
           ALERTS
        ===================================================== */

        .alert{

            border:none;

            border-radius:18px;

            padding:18px 22px;

            backdrop-filter:blur(12px);

            box-shadow:
                    0 10px 30px rgba(0,0,0,0.35);
        }

        .alert-success{

            background:
                    rgba(34,197,94,0.12);

            color:#4ade80;

            border-left:
                    4px solid #22c55e;
        }

        .alert-warning{

            background:
                    rgba(245,158,11,0.12);

            color:#facc15;

            border-left:
                    4px solid #f59e0b;
        }

        .alert-danger{

            background:
                    rgba(239,68,68,0.12);

            color:#f87171;

            border-left:
                    4px solid #ef4444;
        }

        /* =====================================================
           NODO CARD
        ===================================================== */

        .nodo-card{

            background:#111111;

            border-left:
                    4px solid #d4af37;

            border-radius:18px;

            border-top:none;
            border-right:none;
            border-bottom:none;
        }

        /* =====================================================
           BADGES
        ===================================================== */

        .badge{

            border-radius:12px;
        }

        /* =====================================================
           RESPONSIVE
        ===================================================== */

        @media(max-width:991px){

            .sidebar{

                width:100%;

                height:auto;

                position:relative;
            }

            .main-content{

                margin-left:0;

                padding:20px;
            }
        }

    </style>

</head>

<body>

<%

    GestorTickets gestor =
            (GestorTickets) application.getAttribute("gestor");

    String msg =
            request.getParameter("msg");

    int totalTickets = 0;

    String primerTicket = "Sin registros";

    String ultimoTicket = "Sin registros";

    boolean listaVacia = true;

    if (gestor != null &&
        gestor.getLista() != null) {

        totalTickets =
                gestor.totalTickets();

        listaVacia =
                gestor.getLista().estaVacia();

        if (!listaVacia) {

            primerTicket =
                    gestor.getLista()
                          .obtenerPrimerTicket()
                          .getId();

            ultimoTicket =
                    gestor.getLista()
                          .obtenerUltimoTicket()
                          .getId();
        }
    }

%>

<!-- ===================================================== -->
<!-- SIDEBAR -->
<!-- ===================================================== -->

<div class="sidebar">

    <div class="logo-area">

        <div class="logo-circle">

            <i class="bi bi-airplane-fill"></i>

        </div>

        <h3>
            SkyManager
        </h3>

        <small>
            PREMIUM FLIGHT SYSTEM
        </small>

    </div>

    <a class="active"
       href="${pageContext.request.contextPath}/tickets">

        <i class="bi bi-speedometer2"></i>

        Dashboard

    </a>

    <a href="#formulario">

        <i class="bi bi-plus-circle"></i>

        Registrar Ticket

    </a>

    <a href="#tabla">

        <i class="bi bi-table"></i>

        Lista Tickets

    </a>

    <a href="#recorrido">

        <i class="bi bi-arrow-left-right"></i>

        Recorrido Inverso

    </a>

    <a href="${pageContext.request.contextPath}/descargar">

        <i class="bi bi-download"></i>

        Descargar TXT

    </a>

</div>

<!-- ===================================================== -->
<!-- MAIN CONTENT -->
<!-- ===================================================== -->

<div class="main-content">

    <!-- ===================================================== -->
    <!-- TOPBAR -->
    <!-- ===================================================== -->

    <div class="topbar d-flex justify-content-between align-items-center">

        <div>

            <h3 class="titulo mb-0">

                Sistema de Tickets Aéreos

            </h3>

            <small class="subtitulo">

                Gestión mediante lista doblemente enlazada

            </small>

        </div>

        <div>

            <span class="badge bg-primary p-3">

                <i class="bi bi-database-fill"></i>

                Persistencia TXT

            </span>

        </div>

    </div>

    <!-- ===================================================== -->
    <!-- TITULO -->
    <!-- ===================================================== -->

    <div class="text-center mb-5">

        <h1 class="titulo display-5">

            Gestión Inteligente de Tickets

        </h1>

        <p class="subtitulo mt-3">

            Administración premium de tickets aéreos
            con persistencia TXT y recorrido bidireccional.

        </p>

    </div>

    <!-- ===================================================== -->
    <!-- DASHBOARD -->
    <!-- ===================================================== -->

    <div class="row mb-4">

        <div class="col-md-3">

            <div class="panel-card">

                <h6 class="text-muted">

                    Total Tickets

                </h6>

                <div class="stats-number text-primary">

                    <%= totalTickets %>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="panel-card">

                <h6 class="text-muted">

                    Primer Ticket

                </h6>

                <div class="stats-number">

                    <%= primerTicket %>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="panel-card">

                <h6 class="text-muted">

                    Último Ticket

                </h6>

                <div class="stats-number">

                    <%= ultimoTicket %>

                </div>

            </div>

        </div>

        <div class="col-md-3">

            <div class="panel-card">

                <h6 class="text-muted">

                    Estado Lista

                </h6>

                <div class="stats-number">

                    <%= listaVacia ? "Vacía" : "Activa" %>

                </div>

            </div>

        </div>

    </div>

    <!-- ===================================================== -->
    <!-- ALERTAS -->
    <!-- ===================================================== -->

    <%
        if ("agregado".equals(msg)) {
    %>

    <div class="alert alert-success alert-dismissible fade show">

        Ticket agregado correctamente.

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"></button>

    </div>

    <%
        } else if ("editado".equals(msg)) {
    %>

    <div class="alert alert-warning alert-dismissible fade show">

        Ticket actualizado correctamente.

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"></button>

    </div>

    <%
        } else if ("eliminado".equals(msg)) {
    %>

    <div class="alert alert-danger alert-dismissible fade show">

        Ticket eliminado correctamente.

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"></button>

    </div>

    <%
        }
    %>

    <!-- ===================================================== -->
    <!-- FORMULARIO -->
    <!-- ===================================================== -->

    <div class="panel-card"
         id="formulario">

        <h4 class="mb-4">

            Registrar Ticket

        </h4>

        <form action="${pageContext.request.contextPath}/tickets"
              method="post">

            <input type="hidden"
                   name="accion"
                   value="agregar">

            <div class="row mb-3">

                <div class="col-md-6">

                    <label class="form-label">

                        ID Ticket

                    </label>

                    <input type="text"
                           class="form-control"
                           name="id"
                           required>

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Pasajero

                    </label>

                    <input type="text"
                           class="form-control"
                           name="pasajero"
                           required>

                </div>

            </div>

            <div class="row mb-4">

                <div class="col-md-6">

                    <label class="form-label">

                        Origen

                    </label>

                    <input type="text"
                           class="form-control"
                           name="origen"
                           required>

                </div>

                <div class="col-md-6">

                    <label class="form-label">

                        Destino

                    </label>

                    <input type="text"
                           class="form-control"
                           name="destino"
                           required>

                </div>

            </div>

            <button type="submit"
                    class="btn btn-primary btn-lg w-100">

                <i class="bi bi-save"></i>

                Guardar Ticket

            </button>

        </form>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>