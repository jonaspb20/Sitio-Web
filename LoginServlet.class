<%@ page contentType="text/html; charset=UTF-8" %>
<%@ page import="logica.GestorTickets" %>
<%@ page import="modelo.Ticket" %>

<!DOCTYPE html>
<html>

<head>

    <title>Editar Ticket</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <style>

        body{
            background-color:#f4f6f9;
        }

        .card{
            border:none;
            border-radius:12px;
        }

    </style>

</head>

<body>

<%

    // OBTENER GESTOR
    GestorTickets gestor =
            (GestorTickets) application.getAttribute("gestor");

    // OBTENER ID
    String id = request.getParameter("id");

    // BUSCAR TICKET
    Ticket ticket = gestor.buscarPorId(id);

%>

<div class="container mt-5">

    <div class="card shadow p-4">

        <h2 class="mb-4">
            Editar Ticket
        </h2>

        <form action="${pageContext.request.contextPath}/tickets"
              method="post">

            <!-- ACCION -->
            <input type="hidden"
                   name="accion"
                   value="editar">

            <!-- ID -->
            <input type="hidden"
                   name="id"
                   value="<%= ticket.getId() %>">

            <div class="mb-3">

                <label class="form-label">
                    ID del Ticket
                </label>

                <input type="text"
                       class="form-control"
                       value="<%= ticket.getId() %>"
                       disabled>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Pasajero
                </label>

                <input type="text"
                       class="form-control"
                       name="pasajero"
                       value="<%= ticket.getPasajero() %>"
                       required>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Origen
                </label>

                <input type="text"
                       class="form-control"
                       name="origen"
                       value="<%= ticket.getOrigen() %>"
                       required>

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Destino
                </label>

                <input type="text"
                       class="form-control"
                       name="destino"
                       value="<%= ticket.getDestino() %>"
                       required>

            </div>

            <div class="d-flex gap-2">

                <!-- BOTON ACTUALIZAR -->
                <button type="submit"
                        class="btn btn-warning w-100">

                    Actualizar Ticket

                </button>

                <!-- VOLVER -->
                <a href="${pageContext.request.contextPath}/tickets"
                   class="btn btn-secondary w-100">

                    Volver

                </a>

            </div>

        </form>

    </div>

</div>

</body>
</html>
